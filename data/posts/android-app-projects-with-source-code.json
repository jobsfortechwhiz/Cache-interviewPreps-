  "content": "\n\n<div class=\"cards\"></div>\n\n<script>\n  fetch(\"https://interviewprepforinsiders.blogspot.com/p/project-data.html\")\n.then(r => {\n    console.log(r.status);\n    return r.text();\n})\n.then(html => {\n\n    console.log(html);\n\n    const doc = new DOMParser().parseFromString(html,\"text/html\");\n\n    const script = doc.getElementById(\"projects-data\");\n\n    console.log(script);\n\n    const json = script.textContent;\n\n    const projects = JSON.parse(json);\n\n    console.log(projects);\n\n    const container = document.querySelector(\".cards\");\n\n    projects\n    .filter(p => p.type === \"android\")\n    .forEach(function(app){\n\n      container.innerHTML +=\n'<div class=\"card\">' +\n'<h2>' + app.name + '</h2>' +\n'<p>' + app.desc + '</p>' +\n'<div class=\"buttons\">' +\n'<button class=\"btn-source\" onclick=\"buySource(\\'' + app.id + '\\')\">Source Code</button>' +\n'<button class=\"btn-apk\" onclick=\"buyAPK(\\'' + app.id + '\\')\">Download APK</button>' +\n'</div>' +\n'</div>';\n\n    });\n\n})\n.catch(err => console.error(err));\n\n\n/*  \n function buyAPK(id){\n\nlaunchPayment(id,\"apk\");\n\n} */\n  \n  function buyAPK(projectId) {\n\n    window.location.href =\n    \"https://priyanka-nigam.github.io/InterviewPrepStore/checkout.html\" +\n    \"?projectId=\" + encodeURIComponent(projectId) +\n    \"&productType=APK\";\n\n}\n  function buySource(projectId) {\n\n    window.location.href =\n    \"https://priyanka-nigam.github.io/InterviewPrepStore/checkout.html\" +\n    \"?projectId=\" + encodeURIComponent(projectId) +\n    \"&productType=SOURCE\";\n\n}\n  /*\n\nfunction buySource(id){\n\nlaunchPayment(id,\"source\");\n\n}\n*/\n  /*\n  function launchPayment(id, type) {\n\n    // Amount\n    var amount = \"10.00\";\n\n    // Your UPI ID\n    var upiId = \"8932946515@ikwik\";\n\n    // Merchant Name\n    var merchant = \"Priya\";\n\n    // Description\n    var note = id + \" - \" + type;\n\n   var upiUrl =\n\"upi://pay\" +\n\"?pa=\" + encodeURIComponent(upiId) +\n\"&pn=\" + encodeURIComponent(\"Priya Nigam\") +\n\"&am=10.00\" +\n\"&cu=INR\" +\n\"&tn=\" + encodeURIComponent(id + \" APK\");\n\n    // Open UPI app\n    window.location.href = upiUrl;\n\n    // Show alert after a short delay\n    setTimeout(function () {\n\n        alert(\n            \"After completing the payment, if your download doesn't start automatically, please share the payment screenshot/receipt using the Contact page or WhatsApp.\"\n        );\n\n    }, 3000);\n\n}\n*/\n  \n  function launchPayment(projectId, productType){\n\n    openOrderPopup(projectId, productType);\n\n}\n\n</script>\n<style>\n  \n  .cards{\n    display:grid;\n    grid-template-columns:repeat(2,1fr);\n    gap:20px;\n    margin:20px 0;\n}\n\n.card{\n    background:#ffffff;\n    border-radius:12px;\n    padding:20px;\n    box-shadow:0 4px 12px rgba(0,0,0,.12);\n    transition:.3s;\n    border:1px solid #eee;\n}\n\n.card:hover{\n    transform:translateY(-5px);\n    box-shadow:0 8px 20px rgba(0,0,0,.18);\n}\n\n.card h2{\n    margin:0 0 10px;\n    font-size:22px;\n    color:#222;\n}\n\n.card p{\n    margin:0 0 18px;\n    color:#666;\n    font-size:15px;\n    line-height:1.5;\n}\n\n.buttons{\n    display:flex;\n    gap:10px;\n}\n\n.buttons button{\n    flex:1;\n    padding:10px 15px;\n    border:none;\n    border-radius:8px;\n    cursor:pointer;\n    font-size:15px;\n    font-weight:600;\n    transition:.3s;\n}\n\n.btn-source{\n    background:#24292e;\n    color:#fff;\n}\n\n.btn-source:hover{\n    background:#000;\n}\n\n.btn-apk{\n    background:#28a745;\n    color:#fff;\n}\n\n.btn-apk:hover{\n    background:#218838;\n}\n\n@media(max-width:768px){\n\n.cards{\n    grid-template-columns:1fr;\n}\n\n}\n  \n</style><div class=\"blogger-post-footer\">Thankyou for visiting my page.Please ,add a comment and follow us.</div>"
}