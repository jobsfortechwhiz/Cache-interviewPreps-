  "content": "\n\n<div class=\"title-row\">\n<h2>Web Development Topics in Spring </h2>\n<!--\n<a href='https://rzp.io/rzp/PYRfP7l' id='pdfBtn' target='_blank'>\n  <b>Download PDF &#8377;10</b>\n</a> -->\n<button onclick=\"\nlocalStorage.setItem('pdf_product','spring');\nwindow.location.href='https://rzp.io/rzp/VhwcoxDZ';\n\" id='pdfBtn'>\n <b>Download PDF &#8377;10</b>\n</button>\n</div>\n\n<style>\n\n.title-row{\ndisplay:flex !important;\nalign-items:center;\ngap:15px;\nflex-wrap:nowrap !important;\n}\n\n.title-row h2{\nmargin:0 !important;\nwidth:auto !important;\nflex:1;\n}\n\n/* BUTTON */\n\n#pdfBtn{\nposition:relative;\noverflow:hidden;\ndisplay:inline-block !important;\nbackground:linear-gradient(45deg,#00ff00,#00cc66);\ncolor:#fff;\npadding:12px 20px;\nborder-radius:14px;\nfont-weight:700;\ntext-decoration:none;\nfont-size:20px;\nwhite-space:nowrap;\nflex-shrink:0;\n\nbox-shadow:0 0 12px rgba(0,255,0,.45);\n\nanimation:pulse 2s infinite;\ntransition:.35s ease;\n}\n\n/* Hover motion */\n\n#pdfBtn:hover{\ntransform:translateY(-4px) scale(1.05);\nbox-shadow:0 8px 22px rgba(0,255,0,.65);\n}\n\n/* Moving shiny wave */\n\n#pdfBtn::before{\ncontent:\"\";\nposition:absolute;\ntop:0;\nleft:-120%;\nwidth:60%;\nheight:100%;\n\nbackground:rgba(255,255,255,.45);\n\ntransform:skewX(-30deg);\n\nanimation:shine 2.5s infinite;\n}\n\n/* Ripple circle */\n\n#pdfBtn::after{\ncontent:\"\";\nposition:absolute;\nleft:50%;\ntop:50%;\n\nwidth:12px;\nheight:12px;\n\nbackground:rgba(255,255,255,.55);\n\nborder-radius:50%;\n\ntransform:translate(-50%,-50%);\nanimation:ripple 1.8s infinite;\n}\n\n/* Pulse */\n\n@keyframes pulse{\n0%{\ntransform:scale(1);\n}\n50%{\ntransform:scale(1.06);\n}\n100%{\ntransform:scale(1);\n}\n}\n\n/* Shine animation */\n\n@keyframes shine{\n0%{\nleft:-120%;\n}\n100%{\nleft:160%;\n}\n}\n\n/* Ripple animation */\n\n@keyframes ripple{\n0%{\nopacity:.8;\ntransform:translate(-50%,-50%) scale(0);\n}\n100%{\nopacity:0;\ntransform:translate(-50%,-50%) scale(12);\n}\n}\n\n</style><br><hr><br>\n<div id=\"image-grid\"></div>\n\n<style>\n\n#image-grid{\ndisplay:grid;\ngrid-template-columns:repeat(2,1fr);\ngap:22px;\n\ncounter-reset:imgcount;\n}\n\n.image-card{\n\nposition:relative;\n\nbackground:#fff;\npadding:16px;\n\nborder-radius:18px;\n\nbox-shadow:0 4px 16px rgba(0,0,0,.12);\n\ndisplay:flex;\nflex-direction:column;\n\nalign-items:center;\n}\n\n.image-card::before{\n\ncontent:counter(imgcount);\n\ncounter-increment:imgcount;\n\nposition:absolute;\n\ntop:10px;\nleft:10px;\n\nwidth:40px;\nheight:40px;\n\nborder-radius:50%;\n\nbackground:#ff5a36;\ncolor:#fff;\n\ndisplay:flex;\nalign-items:center;\njustify-content:center;\n\nfont-weight:bold;\n\nz-index:20;\n\npointer-events:none;\n}\n\n.image-box{\n\nwidth:100%;\nheight:300px;\n\nbackground:#f3f3f3;\n\nborder-radius:12px;\n\ndisplay:flex;\nalign-items:center;\njustify-content:center;\n\noverflow:hidden;\n}\n\n.image-box img{\n\nmax-width:100%;\nmax-height:100%;\n\nobject-fit:contain;\n\ndisplay:block;\n}\n\n.image-card p{\n\nmargin-top:14px;\n\nfont-size:16px;\nfont-weight:600;\n\ncolor:#111;\n\ntext-align:center;\n}\n\n@media(max-width:768px){\n\n#image-grid{\ngrid-template-columns:1fr;\n}\n\n}\n\n</style>\n\n<script>\nconst captions={\n\n1:\"Common Annotations in Spring\",\n  2:\"@RestController/@controller\",\n\n3:\"Embedded Tomcat Server\",\n  4:\"@RestController\",\n\n5:\"Embedded Container/War file difference\",\n  6:\"@SpringBootApplication\",\n\n7:\"get List of all beans\",\n  8:\"Actuator\",\n\n9:\"@component annotation\",\n\n11:\"@ConditionalOnProperty\",\n\n13:\"@ConditionalOnBean\",\n\n15:\"@ConditionalOnMissingBean\",\n  16:\"@requestMapping\",\n\n17:\"@ConditionalOnClass\",\n\n18:\"JAR file\",\n\n19:\"@ConditionalOnJava\",\n\n20:\"Spring Boot\",\n\n21:\"Dependency Injection\",\n\n22:\"RAD with spring boot\",\n\n23:\"Constuctor/setter injection\",\n24:  \"@value\",\n 25: \"Controller interface\",\n 26: \"What is Spring Boot\",\n  27:\"Whitelabel error page\",\n 28: \"@SpringBootApplication\",\n  29:\"starter dependency\",\n  30:\"Spring initialiser\",\n 31: \"Spring Boot CLI\",\n  32:\"Annotations\",\n  33:\"@SpringBootApplication/@EnableAutoConfiguration difference\",\n  34:\"default web server\",\n 35:\"replace embedded tomcat server\",\n  12:\"disable default web server\",\n  14:\"replace embedded tomcat server\",\n  36:\"Spring framework\",37:\"Spring terminologies\",\n 38: \"Spring modules\",39:\"Inversion of control\",\n  40:\"ApplicationContext/BeanFactory difference\",41:\"ApplicationContext/BeanFactory difference\",\n  42:\"Spring Actuator\",\n 43: \"Spring boot starter\",44:\"Starter depenencies\",45:\"Starter depenencies\",10:\"disable auto-configuration\",46:\"disable auto-configuration\",\n 47: \"singleton /stateful bean\",48:\"Spring Boot\"\n\n  };\nconst total=50;     // your actual count\n\nconst grid=document.getElementById(\"image-grid\");\n\nlet html='';\n\nfor(let i=1;i<=total;i++){\nconst caption =\ncaptions[i] || `Image ${i}`;\nconst jpg=\n`https://raw.githubusercontent.com/PRIYANKA-Nigam/images/master/img_${i}.jpg`;\n\nconst JPG=\n`https://raw.githubusercontent.com/PRIYANKA-Nigam/images/master/img_${i}.JPG`;\n\nconst png=\n`https://raw.githubusercontent.com/PRIYANKA-Nigam/images/master/img_${i}.png`;\n\nconst PNG=\n`https://raw.githubusercontent.com/PRIYANKA-Nigam/images/master/img_${i}.PNG`;\n\nconst finalUrl = jpg;\n  const formats=[jpg,JPG,png,PNG];\n\nhtml += `\n\n<div class=\"image-card\">\n\n<div class=\"image-box\">\n\n<a\nid=\"link${i}\"\nhref=\"#\"\ndata-lightbox=\"springgallery\"\ndata-title=\"${caption}\"\n>\n\n<img\nid=\"img${i}\"\nsrc=\"${jpg}\"\n\nonerror=\"\n\nlet arr=['${JPG}','${png}','${PNG}'];\n\nlet idx=Number(this.dataset.idx||0);\n\nif(idx<arr.length){\n\nthis.src=arr[idx];\n\ndocument.getElementById('link${i}').href=arr[idx];\n\nthis.dataset.idx=idx+1;\n\n}\nelse{\n\nthis.closest('.image-card').remove();\n\n}\n\"\n\nonload=\"\ndocument.getElementById('link${i}').href=this.src;\n\"\n\n>\n\n</a>\n\n</div>\n\n<p>${caption}</p>\n\n</div>\n\n`;\n}\ndocument.getElementById(\"image-grid\").innerHTML = html;\ngrid.innerHTML=html;\n\n</script>\n<div class=\"blogger-post-footer\">Thankyou for visiting my page.Please ,add a comment and follow us.</div>"
}