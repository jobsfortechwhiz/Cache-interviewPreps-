Fa9PpyqOU/s320/Screenshot_20210719-063755.png\"/></div><div class=\"separator\" style=\"clear: both;\"><img alt=\"\" border=\"0\" height=\"320\" data-original-height=\"1440\" data-original-width=\"720\" src=\"https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEgw3w554uUfbUgVXeaA0nSEHUKAeHUuJqZbQEcan9Iui0cwxAF6CJzrN6wCaCXux9a11X_YRXbbDRj0LQUOuG9kCZtd6PzOSefXY0bAgJxdGSlcYzVZ2j4WByILGu9_1iz8eK1uJtF3IazWMFgqUd-7oCTXvXWlqkBgj2WGqm_64TwmjLLpwgXFL9s4n1Y/s320/Screenshot_20210719-064107.png\"/></div><div class=\"separator\" style=\"clear: both;\"><img alt=\"\" border=\"0\" height=\"320\" data-original-height=\"1440\" data-original-width=\"720\" src=\"https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEjtEt-OJ3gghUd6zxVLXv8uGdZMv9ZbtcdWFEqsMUcmhlcue2IEh9Y4o-6i_qo8QOBJLhHxIfs9obl7n7e26OA3ZpNRFfCqrqXPRqUsnnoC6Pz1AUbghQs_n2KgZbna_vVt2RCvZCtVvkA0LXuGkbn6sTprvo8I1yvd5F9c_bElUUaNm1f8wzqIAHWgzU8/s320/Screenshot_20210719-064152.png\"/></div>\n</div>\n\n\n\n\n<style>\n\n#image-grid{\n\ndisplay:grid;\ngrid-template-columns:repeat(2,1fr);\ngap:20px;\n\n}\n\n.image-card{\n\nbackground:#fff;\npadding:15px;\nborder-radius:18px;\nbox-shadow:0 4px 15px rgba(0,0,0,.15);\n\ndisplay:flex;\nflex-direction:column;\n\noverflow:visible;\n\nposition:relative;\n}\n.image-box{\n\nwidth:100%;\n\nheight:320px;\n\nbackground:#f4f4f4;\n\nborder-radius:12px;\n\ndisplay:flex;\n\nalign-items:center;\n\njustify-content:center;\n\noverflow:hidden;\n\nmargin-bottom:12px;\n\n}\n.image-box img{\n\nmax-width:100%;\n\nmax-height:100%;\n\nwidth:auto;\n\nheight:auto;\n\nobject-fit:contain;\n\ndisplay:block;\n\n}\n.image-card p{\n\nvisibility:visible !important;\n\nopacity:1 !important;\n\nmargin-top:10px;\n\npadding:10px;\n\nfont-size:15px;\n\nfont-weight:600;\n\nline-height:1.5;\n\ncolor:#111 !important;\n\nbackground:#fafafa;\n\nborder-radius:10px;\n\nword-break:break-word;\n\nposition:relative;\n  display:none !important;\n\nz-index:9999;\n}\n \n.image-card::before{\n\ncontent:counter(imgcount);\n\nposition:absolute;\n\ntop:10px;\nleft:10px;\n\nwidth:40px;\nheight:40px;\n\nborder-radius:50%;\n\nbackground:#ff5a36;\n\ncolor:#fff;\n\ndisplay:flex;\n\nalign-items:center;\njustify-content:center;\n\nfont-weight:bold;\n\nz-index:99;\n\n}\n\n#image-grid{\n\ncounter-reset:imgcount;\n\n}\n\n.image-card{\n\ncounter-increment:imgcount;\n\n}\n/* REMOVE FULLSCREEN CAPTIONS COMPLETELY */\n\n/* GRID CAPTIONS — ALWAYS VISIBLE */\n\n.image-card p{\n\ndisplay:block !important;\n\nvisibility:visible !important;\n\nopacity:1 !important;\n\nmargin-top:12px !important;\n\nfont-size:15px !important;\n\nfont-weight:600 !important;\n\ncolor:#111 !important;\n\nbackground:#fff !important;\n\nposition:relative !important;\n\nz-index:10 !important;\n\n}\n\n/* LIGHTBOX ABOVE PAGE */\n\n.lightboxOverlay{\n\nz-index:999999 !important;\n\n}\n\n.lightbox{\n\nz-index:1000000 !important;\n\n}\n\n/* HIDE LIGHTBOX CAPTIONS ONLY */\n\n.lightbox .lb-dataContainer,\n.lightbox .lb-data,\n.lightbox .lb-details,\n.lightbox .lb-caption,\n.lightbox .lb-number{\n\ndisplay:none !important;\n\n}\n</style>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/tesseract.js@5/dist/tesseract.min.js\"></script>\n\n<script>\n\nconst captions=[\n\n\"Git Vs Bitbucket\",\"Jira Project role\",\"git checkout branchname\",\"git branch -r\",\"git push\",\"git log --oneline -3\",\n  \"git fetch\",\"git checkout\",\"Fix a broken commit\",\"undo changes in git\",\"View commit history\",\"git reset\",\n  \"Switching to a different commit\",\"git merge\",\"git clean\",\"git show\",\"git diff --name-only\",\"git log filename\",\n  \"git log\"\n\n];\nconst grid=\ndocument.getElementById('image-grid');\n\nconst imgs=\ndocument.querySelectorAll(\n'#source-images img'\n);\n\nimgs.forEach((img,index)=>{\n\nconst url=img.src;\n\n/*const caption=\nimg.alt ||\n`Image ${index+1}`; */\n  const caption=\ncaptions[index] || \"Add Caption\";\n\ngrid.innerHTML += `\n\n<div class=\"image-card\">\n\n<div class=\"image-box\">\n\n<a\nhref=\"${url}\"\ndata-lightbox=\"mygallery\"\ndata-title=\"\"\n>\n\n<img src=\"${url}\"\nalt=\"${caption}\">\n\n</a>\n\n</div>\n\n<p>\n\n ${caption}\n\n</p>\n\n</div>\n\n`;\n});\n\n</script><div class=\"blogger-post-footer\">Thankyou for visiting my page.Please ,add a comment and follow us.</div>"
}
