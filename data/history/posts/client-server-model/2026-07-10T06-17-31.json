440/Screenshot_20210728-192708.png\" style=\"display: block; padding: 1em 0; text-align: center; \"><img alt=\"\" border=\"0\" height=\"320\" data-original-height=\"1440\" data-original-width=\"720\" src=\"https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEikDACMYpKkIosAGk5iKxBACgo-s_HRMxRu7SGCHZEoUzLDyqO4ouyb6QyFO13tx7C59aM7wSoq2E7IPq-rABkUD0k4U6WSgH0OU17YGw3m1Kuc9GRJUyR_JcN8iv8SknGrsmYNwUgrsu7PwDS_Frx6E0wxYwIn6VaAD4_EXDd70GhJAn2lDM_uVXej7Rg/s320/Screenshot_20210728-192708.png\"/></a></div><div class=\"separator\" style=\"clear: both;\"><a href=\"https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEhAwSNtqW-F0EFiNKE0OMKek_Ov_c0MMf7pMczHDcikcoF9gRnWOzHXH3wJLjhUjdfIj3WfSI6SA-8RHA-qmZWAVSi9PIZVlOWVu6AzqFt3aNi3wi-LYHRrIAjKt1Ne_7RU4UU1AgtF6ADQAHPUSHlDOqNIC3cBT5HZyk9D1lh_C0MfJwSfIUK0_GqQt3o/s1440/Screenshot_20210728-192926.png\" style=\"display: block; padding: 1em 0; text-align: center; \"><img alt=\"\" border=\"0\" height=\"320\" data-original-height=\"1440\" data-original-width=\"720\" src=\"https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEhAwSNtqW-F0EFiNKE0OMKek_Ov_c0MMf7pMczHDcikcoF9gRnWOzHXH3wJLjhUjdfIj3WfSI6SA-8RHA-qmZWAVSi9PIZVlOWVu6AzqFt3aNi3wi-LYHRrIAjKt1Ne_7RU4UU1AgtF6ADQAHPUSHlDOqNIC3cBT5HZyk9D1lh_C0MfJwSfIUK0_GqQt3o/s320/Screenshot_20210728-192926.png\"/></a></div><div class=\"separator\" style=\"clear: both;\"><a href=\"https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEg3-Pk10SDJ3bxSuf-KOT3VilHk98HnX-KpUSpafQ2NJpmKnBOwB3tl2ubhzoVTxxDHdjVCASM9mRYrbgmEdNA5ieqaH0zPW4txDJcc_cJGz10Ej0RhtBezAqT78Rh7D1G4QAA0j4fNiH7YgsAVGEsKinR-lVOhwA4smqYH73bhi41mvNjVzZfKZ3dKod0/s1440/Screenshot_20210728-200408.png\" style=\"display: block; padding: 1em 0; text-align: center; \"><img alt=\"\" border=\"0\" height=\"320\" data-original-height=\"1440\" data-original-width=\"720\" src=\"https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEg3-Pk10SDJ3bxSuf-KOT3VilHk98HnX-KpUSpafQ2NJpmKnBOwB3tl2ubhzoVTxxDHdjVCASM9mRYrbgmEdNA5ieqaH0zPW4txDJcc_cJGz10Ej0RhtBezAqT78Rh7D1G4QAA0j4fNiH7YgsAVGEsKinR-lVOhwA4smqYH73bhi41mvNjVzZfKZ3dKod0/s320/Screenshot_20210728-200408.png\"/></a></div>\n</div>\n\n\n\n\n<style>\n\n#image-grid{\n\ndisplay:grid;\ngrid-template-columns:repeat(2,1fr);\ngap:20px;\n\n}\n\n.image-card{\n\nbackground:#fff;\npadding:15px;\nborder-radius:18px;\nbox-shadow:0 4px 15px rgba(0,0,0,.15);\n\ndisplay:flex;\nflex-direction:column;\n\noverflow:visible;\n\nposition:relative;\n}\n.image-box{\n\nwidth:100%;\n\nheight:320px;\n\nbackground:#f4f4f4;\n\nborder-radius:12px;\n\ndisplay:flex;\n\nalign-items:center;\n\njustify-content:center;\n\noverflow:hidden;\n\nmargin-bottom:12px;\n\n}\n.image-box img{\n\nmax-width:100%;\n\nmax-height:100%;\n\nwidth:auto;\n\nheight:auto;\n\nobject-fit:contain;\n\ndisplay:block;\n\n}\n.image-card p{\n\nvisibility:visible !important;\n\nopacity:1 !important;\n\nmargin-top:10px;\n\npadding:10px;\n\nfont-size:15px;\n\nfont-weight:600;\n\nline-height:1.5;\n\ncolor:#111 !important;\n\nbackground:#fafafa;\n\nborder-radius:10px;\n\nword-break:break-word;\n\nposition:relative;\n  display:none !important;\n\nz-index:9999;\n}\n \n.image-card::before{\n\ncontent:counter(imgcount);\n\nposition:absolute;\n\ntop:10px;\nleft:10px;\n\nwidth:40px;\nheight:40px;\n\nborder-radius:50%;\n\nbackground:#ff5a36;\n\ncolor:#fff;\n\ndisplay:flex;\n\nalign-items:center;\njustify-content:center;\n\nfont-weight:bold;\n\nz-index:99;\n\n}\n\n#image-grid{\n\ncounter-reset:imgcount;\n\n}\n\n.image-card{\n\ncounter-increment:imgcount;\n\n}\n/* REMOVE FULLSCREEN CAPTIONS COMPLETELY */\n\n/* GRID CAPTIONS ? ALWAYS VISIBLE */\n\n.image-card p{\n\ndisplay:block !important;\n\nvisibility:visible !important;\n\nopacity:1 !important;\n\nmargin-top:12px !important;\n\nfont-size:15px !important;\n\nfont-weight:600 !important;\n\ncolor:#111 !important;\n\nbackground:#fff !important;\n\nposition:relative !important;\n\nz-index:10 !important;\n\n}\n\n/* LIGHTBOX ABOVE PAGE */\n\n.lightboxOverlay{\n\nz-index:999999 !important;\n\n}\n\n.lightbox{\n\nz-index:1000000 !important;\n\n}\n\n/* HIDE LIGHTBOX CAPTIONS ONLY */\n\n.lightbox .lb-dataContainer,\n.lightbox .lb-data,\n.lightbox .lb-details,\n.lightbox .lb-caption,\n.lightbox .lb-number{\n\ndisplay:none !important;\n\n}\n</style>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/tesseract.js@5/dist/tesseract.min.js\"></script>\n\n<script>\n\nconst captions=[\n\n\" \",\" \",\"2 tier architecture\",\"File Server\",\" \",\" \",\"Content type - MIME type \"\n\n\n];\nconst grid=\ndocument.getElementById('image-grid');\n\nconst imgs=\ndocument.querySelectorAll(\n'#source-images img'\n);\n\nimgs.forEach((img,index)=>{\n\nconst url=img.src;\n\n/*const caption=\nimg.alt ||\n`Image ${index+1}`; */\n  const caption=\ncaptions[index] || \"Add Caption\";\n\ngrid.innerHTML += `\n\n<div class=\"image-card\">\n\n<div class=\"image-box\">\n\n<a\nhref=\"${url}\"\ndata-lightbox=\"mygallery\"\ndata-title=\"\"\n>\n\n<img src=\"${url}\"\nalt=\"${caption}\">\n\n</a>\n\n</div>\n\n<p>\n\n ${caption}\n\n</p>\n\n</div>\n\n`;\n});\n\n</script><div class=\"blogger-post-footer\">Thankyou for visiting my page.Please ,add a comment and follow us.</div>"
}