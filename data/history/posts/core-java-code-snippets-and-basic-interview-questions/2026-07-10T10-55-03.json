ndisplay:flex;\n\nalign-items:center;\n\njustify-content:center;\n\noverflow:hidden;\n\nmargin-bottom:12px;\n\n}\n.image-box img{\n\nmax-width:100%;\n\nmax-height:100%;\n\nwidth:auto;\n\nheight:auto;\n\nobject-fit:contain;\n\ndisplay:block;\n\n}\n.image-card p{\n\nvisibility:visible !important;\n\nopacity:1 !important;\n\nmargin-top:10px;\n\npadding:10px;\n\nfont-size:15px;\n\nfont-weight:600;\n\nline-height:1.5;\n\ncolor:#111 !important;\n\nbackground:#fafafa;\n\nborder-radius:10px;\n\nword-break:break-word;\n\nposition:relative;\n  display:none !important;\n\nz-index:9999;\n}\n \n.image-card::before{\n\ncontent:counter(imgcount);\n\nposition:absolute;\n\ntop:10px;\nleft:10px;\n\nwidth:40px;\nheight:40px;\n\nborder-radius:50%;\n\nbackground:#ff5a36;\n\ncolor:#fff;\n\ndisplay:flex;\n\nalign-items:center;\njustify-content:center;\n\nfont-weight:bold;\n\nz-index:99;\n\n}\n\n#image-grid{\n\ncounter-reset:imgcount;\n\n}\n\n.image-card{\n\ncounter-increment:imgcount;\n\n}\n/* REMOVE FULLSCREEN CAPTIONS COMPLETELY */\n\n/* GRID CAPTIONS ? ALWAYS VISIBLE */\n\n.image-card p{\n\ndisplay:block !important;\n\nvisibility:visible !important;\n\nopacity:1 !important;\n\nmargin-top:12px !important;\n\nfont-size:15px !important;\n\nfont-weight:600 !important;\n\ncolor:#111 !important;\n\nbackground:#fff !important;\n\nposition:relative !important;\n\nz-index:10 !important;\n\n}\n\n/* LIGHTBOX ABOVE PAGE */\n\n.lightboxOverlay{\n\nz-index:999999 !important;\n\n}\n\n.lightbox{\n\nz-index:1000000 !important;\n\n}\n\n/* HIDE LIGHTBOX CAPTIONS ONLY */\n\n.lightbox .lb-dataContainer,\n.lightbox .lb-data,\n.lightbox .lb-details,\n.lightbox .lb-caption,\n.lightbox .lb-number{\n\ndisplay:none !important;\n\n}\n</style>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/tesseract.js@5/dist/tesseract.min.js\"></script>\n\n<script>\n\nconst grid=\ndocument.getElementById('image-grid');\n\nconst imgs=\ndocument.querySelectorAll(\n'#source-images img'\n);\n\nimgs.forEach((img,index)=>{\n\nconst url=img.src;\n\nconst caption=\nimg.alt ||\n`Image ${index+1}`;\n\ngrid.innerHTML += `\n\n<div class=\"image-card\">\n\n<div class=\"image-box\">\n\n<a\nhref=\"${url}\"\ndata-lightbox=\"mygallery\"\ndata-title=\"\"\n>\n\n<img src=\"${url}\">\n\n</a>\n\n</div>\n\n<p>\n\n${index+1}. ${caption}\n\n</p>\n\n</div>\n\n`;\n});\n\n</script><div class=\"blogger-post-footer\">Thankyou for visiting my page.Please ,add a comment and follow us.</div>"
