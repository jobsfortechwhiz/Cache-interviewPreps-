  "content": "<div class=\"title-row\">\n<h2>Project Tracking Tool - Jira</h2>\n<!--\n<a href='https://rzp.io/rzp/PYRfP7l' id='pdfBtn' target='_blank'>\n  <b>Download PDF &#8377;10</b>\n</a> -->\n<button onclick=\"\nlocalStorage.setItem('pdf_product','jira');\nwindow.location.href='https://rzp.io/rzp/VhwcoxDZ';\n\" id='pdfBtn'>\n <b>Download PDF &#8377;10</b>\n</button>\n</div>\n\n<style>\n\n.title-row{\ndisplay:flex !important;\nalign-items:center;\ngap:15px;\nflex-wrap:nowrap !important;\n}\n\n.title-row h2{\nmargin:0 !important;\nwidth:auto !important;\nflex:1;\n}\n\n/* BUTTON */\n\n#pdfBtn{\nposition:relative;\noverflow:hidden;\ndisplay:inline-block !important;\nbackground:linear-gradient(45deg,#00ff00,#00cc66);\ncolor:#fff;\npadding:12px 20px;\nborder-radius:14px;\nfont-weight:700;\ntext-decoration:none;\nfont-size:20px;\nwhite-space:nowrap;\nflex-shrink:0;\n\nbox-shadow:0 0 12px rgba(0,255,0,.45);\n\nanimation:pulse 2s infinite;\ntransition:.35s ease;\n}\n\n/* Hover motion */\n\n#pdfBtn:hover{\ntransform:translateY(-4px) scale(1.05);\nbox-shadow:0 8px 22px rgba(0,255,0,.65);\n}\n\n/* Moving shiny wave */\n\n#pdfBtn::before{\ncontent:\"\";\nposition:absolute;\ntop:0;\nleft:-120%;\nwidth:60%;\nheight:100%;\n\nbackground:rgba(255,255,255,.45);\n\ntransform:skewX(-30deg);\n\nanimation:shine 2.5s infinite;\n}\n\n/* Ripple circle */\n\n#pdfBtn::after{\ncontent:\"\";\nposition:absolute;\nleft:50%;\ntop:50%;\n\nwidth:12px;\nheight:12px;\n\nbackground:rgba(255,255,255,.55);\n\nborder-radius:50%;\n\ntransform:translate(-50%,-50%);\nanimation:ripple 1.8s infinite;\n}\n\n/* Pulse */\n\n@keyframes pulse{\n0%{\ntransform:scale(1);\n}\n50%{\ntransform:scale(1.06);\n}\n100%{\ntransform:scale(1);\n}\n}\n\n/* Shine animation */\n\n@keyframes shine{\n0%{\nleft:-120%;\n}\n100%{\nleft:160%;\n}\n}\n\n/* Ripple animation */\n\n@keyframes ripple{\n0%{\nopacity:.8;\ntransform:translate(-50%,-50%) scale(0);\n}\n100%{\nopacity:0;\ntransform:translate(-50%,-50%) scale(12);\n}\n}\n\n</style><br><hr><br>\n<div id=\"image-grid\"></div>\n\n<style>\n\n#image-grid{\ndisplay:grid;\ngrid-template-columns:repeat(2,1fr);\ngap:20px;\n}\n\n.image-card{\nbackground:#fff;\npadding:16px;\nborder-radius:16px;\nbox-shadow:0 4px 14px rgba(0,0,0,.12);\ntext-align:center;\n  display:flex;\nflex-direction:column;\n\nalign-items:center;\n\noverflow:visible !important;\n}\n\n.image-box{\n\nwidth:100%;\nheight:280px;\nmargin-bottom:10px;\ndisplay:flex;\nalign-items:center;\njustify-content:center;\n\noverflow:visible;        /* IMPORTANT */\n\nheight:300px;\nbackground:#f2f2f2;\nborder-radius:12px;\n\npadding:12px;\nbox-sizing:border-box;\n}\n\n.image-box img{\n\nmax-width:100%;\nmax-height:100%;\n\nwidth:auto;\nheight:auto;\n\nobject-fit:contain;\n\ndisplay:block;\n}\n.image-card p{\n\ndisplay:block !important;\n\nmargin-top:14px !important;\npadding:8px 5px !important;\n\nfont-size:16px !important;\nfont-weight:600 !important;\n\ncolor:#111 !important;     /* force visible text */\n\ntext-align:center;\n\nline-height:1.5;\n\nposition:relative;\nz-index:20;                /* keep above other layers */\n}\n#image-grid{\ncounter-reset:imgcount;\n}\n\n.image-card{\nposition:relative;\nisolation:isolate;\ncounter-increment:imgcount;\n}\n.image-card .img-num{\n\nposition:absolute;\ntop:10px;\nleft:10px;\n\nz-index:2;\npointer-events:none;\n}\n\n  \n  #galleryOverlay{\n\nposition:fixed;\ninset:0;\n\nbackground:rgba(0,0,0,.92);\n\nz-index:999999;\n\ndisplay:flex;\njustify-content:center;\nalign-items:center;\n}\n\n.viewer{\n\ndisplay:flex;\nalign-items:center;\ngap:20px;\n}\n\n.viewer img{\n\nmax-width:90vw;\nmax-height:90vh;\n}\n\n.viewer button{\n\nfont-size:40px;\nbackground:none;\nborder:none;\ncolor:white;\ncursor:pointer;\n}\n  .lightbox-link{\ndisplay:block;\nwidth:100%;\nheight:100%;\n}\n\n.lightbox-link img{\nwidth:100%;\nheight:100%;\nobject-fit:contain;\n}\n  .image-card{\nposition:relative;\n}\n\n.img-number{\n\nposition:absolute;\n\ntop:8px;\nleft:8px;\n\nwidth:38px;\nheight:38px;\n\nbackground:#ff5a36;\ncolor:#fff;\n\nborder-radius:50%;\n\ndisplay:flex;\nalign-items:center;\njustify-content:center;\n\nfont-weight:bold;\nfont-size:16px;\n\nz-index:50;\n\nbox-shadow:0 3px 10px rgba(0,0,0,.35);\n\npointer-events:none;\n}\n</style>\n\n<script>\n\nconst FOLDER_ID=\"1ZZzB-SBHM2M_Fna6ZAjf3rw_LqiAWB5r\";\nconst API_KEY=\"AIzaSyCx8I3mIY2maY_yZ_6rChJcu73LcUbGCrY\";\n\n/* YOUR MANUAL CAPTIONS */\n\nconst captions=[\n\n\"Default Project Rule in Jira\",\n\n\"HyperSQL\",\n\n\"Things in Jira\",\n\n\"Filter\",\n\n\"License key\",\n\n\"Test Session\",\n\n\"Filter results\",\n\n\"Components\",\n\n\"Online Archiving\",\"Workflow\",\"Cloning an issue\"\n\n];\n\nfetch(\n`https://www.googleapis.com/drive/v3/files?q='${FOLDER_ID}'+in+parents&key=${API_KEY}&fields=files(id,name)`\n)\n\n.then(response=>response.json())\n\n.then(data=>{\n\nconst grid=document.getElementById(\"image-grid\");\nlet galleryName=\"gallery1\";\ndata.files.forEach((file,index)=>{\n\nconst imgUrl=\n`https://drive.google.com/thumbnail?id=${file.id}&sz=w1200`;\n\nconst caption=\ncaptions[index] || \"Add Caption\";\n\ngrid.innerHTML += `\n\n<div class=\"image-card\">\n\n<span class=\"img-number\">${index+1}</span>\n\n<div class=\"image-box\">\n\n<img\nclass=\"gallery-img\"\nsrc=\"${imgUrl}\"\nalt=\"${caption}\"\nonclick=\"openGallery(${index})\"\n/>\n\n</div>\n\n<p>${caption}</p>\n\n</div>\n\n`;\n});\n\n})\n\n.catch(err=>console.log(err));\n\n</script>\n<script>\n\nlet gallery=[];\n\nfunction openGallery(i){\n\ngallery = Array.from(\ndocument.querySelectorAll('.gallery-img')\n);\n\nlet current=i;\n\nfunction show(){\n\nconst overlay=document.createElement('div');\n\noverlay.id='galleryOverlay';\n\noverlay.innerHTML=`\n<div class=\"viewer\">\n\n<button onclick=\"prevImg()\">?</button>\n\n<img id=\"viewerImg\" src=\"${gallery[current].src}\">\n\n<button onclick=\"nextImg()\">?</button>\n\n</div>\n`;\n\ndocument.body.appendChild(overlay);\n\nwindow.nextImg=function(){\n\ncurrent=(current+1)%gallery.length;\n\ndocument.getElementById('viewerImg').src=\ngallery[current].src;\n};\n\nwindow.prevImg=function(){\n\ncurrent=(current-1+gallery.length)%gallery.length;\n\ndocument.getElementById('viewerImg').src=\ngallery[current].src;\n};\n\noverlay.onclick=e=>{\nif(e.target.id===\"galleryOverlay\")\noverlay.remove();\n};\n\n}\n\nshow();\n\n}\n\n</script>\n<div class=\"blogger-post-footer\">Thankyou for visiting my page.Please ,add a comment and follow us.</div>"
}