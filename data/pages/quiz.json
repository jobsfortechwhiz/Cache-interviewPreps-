  "content": "\n<div class=\"my-top-header\">\n\n  <h1>INTERVIEW PREPS</h1>\n\n  <div class=\"my-top-links\">\n\n    <a href=\"/search/\">All</a>\n\n    <a href=\"/search/label/Java interview Questions\">? Java</a>\n\n    <a href=\"/search/label/Spring interview Questions\">? Spring</a>\n\n    <a href=\"/search/label/Android interview Questions\">? Android</a>\n\n    <a href=\"/search/label/PHP web development Questions\">? PHP</a>\n\n    <a href=\"/p/all-spoken-english-content.html\">? English</a>\n\n    <a href=\"/search/label/HR | Managerial interview Questions\">? HR</a>\n\n    <a href=\"/search/label/Cloud DevOps | GitOps interview questions\">? DevOps</a>\n\n    <a href=\"/search/label/Technical interview questions\">? Technical</a>\n\n  </div>\n\n</div>\n<style>\n  .option{\ndisplay:block;\npadding:8px;\nmargin:5px 0;\nborder-radius:5px;\n}\n  .option.correct{\nborder:2px solid green;\nbackground:#e7ffe7;\ndisplay:block;\npadding:8px;\nmargin:5px 0;\n}\n\n.option.wrong{\nborder:2px solid red;\nbackground:#ffe7e7;\ndisplay:block;\npadding:8px;\nmargin:5px 0;\n}\n.loader{\n\nwidth:35px;\nheight:35px;\nborder:4px solid #ddd;\nborder-top:4px solid #333;\nborder-radius:50%;\nanimation:spin 1s linear infinite;\ndisplay:inline-block;\n\n}\n\n\n@keyframes spin{\n\n100%{\ntransform:rotate(360deg);\n}\n\n}\n\n.wrong{\nborder:2px solid red;\nbackground:#ffe7e7;\n}\nbody{\nfont-family:Arial;\nmax-width:900px;\nmargin:auto;\npadding:20px;\n}\n\n.question{\nmargin-bottom:25px;\npadding:15px;\nborder:1px solid #ddd;\n}\n\nbutton{\npadding:10px 20px;\ncursor:pointer;\n}\n\n.result{\nfont-size:22px;\nfont-weight:bold;\nmargin-top:30px;\n}\n  /* Make quiz area wider */\n/* Full desktop width */\n/* Break Blogger width restrictions */\n.content-outer,\n.content-inner,\n.main-inner,\n.main,\n.page_body,\n.post-outer,\n.post,\n.post-body,\n.entry-content {\n\n    max-width:none !important;\n    width:100% !important;\n}\n\nbody{\n    overflow-x:hidden;\n  padding-top:160px;\n}\n\n#quiz,\n#quizBox{\n\n    width:98% !important;\n\n    max-width:1600px !important;\n\n    margin:20px auto !important;\n}\n\n.question,\n.question-card{\n\n    width:100% !important;\n\n    max-width:none !important;\n}\n  \n.question p,\n.question h3{\n\n    width:100% !important;\n\n    max-width:none !important;\n\n    font-size:24px !important;\n\n    line-height:1.7 !important;\n}\n  \n  .custom-header{\n    display:none !important;\n}\n.my-top-header{\n\nposition:fixed;\n\ntop:25px;    /* leave space for breadcrumb above */\n\nleft:30px;\nright:30px;\n\nwidth:100%;\n\n  z-index:9990; /* my buy button was getting hidden.so replaced 999999 to 9990 */\n\nbackground:#111;\n\ntext-align:center;   /* center all content */\n\npadding:15px 0;\n}\n\n\n.my-top-header h1{\n\nmargin:0;\n\ntext-align:center;\n\ndisplay:block;\n\nwidth:100%;\n\nfont-size:42px;\n\ncolor:#fff;\n}\n\n.my-top-links{\n\n    display:flex;\n\n    justify-content:center;\n\n    flex-wrap:wrap;\n\n    gap:12px;\n}\n\n.my-top-links a{\n\n    color:#ff7357;\n\n    text-decoration:none;\n\n    font-size:20px;\n\n    font-weight:600;\n}\n\n.my-top-links a:hover{\n\n    color:#fff;\n}\n  .breadcrumbs{\n\nposition:fixed;\n\ntop:0;\n/* same margins as header */\nleft:20px !important;\n\nright:20px !important;\n\nwidth:auto !important;\n\ntransform:none !important;\npadding:8px 20px;\n\nborder-radius:0 0 10px 10px;\n\nz-index:1000000;\n\nwhite-space:nowrap;\n  \n\nfont-size:14px;\n\nbox-sizing:border-box;\n\n}\n\n.breadcrumbs a{\n\ntext-decoration:none;\n\nfont-weight:600;\n}\nnav,\n.navbar,\n.navigation,\n.main-nav,\n#menu{\n\ndisplay:none !important;\n}\n  .centered-top-firstline{\n\nposition:fixed !important;\n\ntop:65px !important;\n\nright:12px !important;\n\nleft:auto !important;\n\nz-index:9999999 !important;\n\n}\n  \n .search, .search-expand-text{\n\nposition:fixed !important;\n\ntop:65px !important;\n\nright:70px !important;\n\nleft:auto !important;\n\nz-index:9999999 !important;\n\n}\n  \n /* Submit button styling + ripple effect */ \n  .submit-btn{\n\n    color:#fff !important;\n\n    background:#ff7357 !important;\n\n    font-size:22px !important;\n\n    font-weight:800 !important;\n\n    letter-spacing:.5px;\n\n    text-shadow:0 1px 2px rgba(0,0,0,.3);\n\n    padding:16px 45px !important;\n\n    border:none !important;\n}\n\n.submit-btn:hover{\n\n    background:#ff5722 !important;\n}\n.submit-btn:active::after{\n\ncontent:\"\";\n\nposition:absolute;\n\nwidth:200px;\nheight:200px;\n\nleft:50%;\ntop:50%;\n\nbackground:rgba(255,255,255,.4);\n\nborder-radius:50%;\n\ntransform:\ntranslate(-50%,-50%)\nscale(0);\n\nanimation:ripple .5s linear;\n\n}\n\n#submitBtn{\n    color:#fff !important;\n    background:#ff7357 !important;\n}\n\n@keyframes ripple{\n\nto{\n\ntransform:\ntranslate(-50%,-50%)\nscale(3);\n\nopacity:0;\n\n}\n\n}\n  /* answer options need more width too */\n  .question label {\n\ndisplay:block;\n\npadding:12px 15px;\n\nmargin:8px 0;\n\nborder-radius:10px;\n\ncursor:pointer;\n\ntransition:.2s;\n\n}\n\n\n.question label:hover{\n\nbackground:#333;\n\n}\n\n\ninput[type=\"radio\"]{\ntransform:scale(1.3);\nmargin-right:10px;\n}\n  #quizTitle{\n    \n    font-size:34px;\n\n    font-weight:800;\n\n    color:#ff7357;\n\n    text-align:center;\n\n    margin:20px auto 35px;\n}\n</style>\n\n\n\n<h1 id=\"quizTitle\"></h1>\n\n<script>\n\nconst articleUrl =\nnew URLSearchParams(location.search)\n.get(\"url\");\n\nfetch(articleUrl)\n.then(r => r.text())\n.then(html => {\n\n   const doc =\n   new DOMParser()\n   .parseFromString(html,\"text/html\");\n\n const title =\ndoc.querySelector('h3.post-title');\n\n\n  if(title){\n  document.getElementById('quizTitle').textContent =\n  title.textContent.trim();\n}\n\n});\n\n</script>\n<div id=\"debug\">\n<div class=\"loader\"></div>\nLoading quiz...\n</div>\n\n<div id=\"quiz\"></div>\n<div id=\"score\"></div>\n<button id=\"submitBtn\" onclick=\"submitQuiz()\">\nSubmit Quiz\n</button>\n\n<div id=\"result\"></div>\n<script type=\"module\">\n\nimport { initializeApp }\nfrom \"https://www.gstatic.com/firebasejs/12.0.0/firebase-app.js\";\n\nimport {\ngetFirestore,\ndoc,\ngetDoc,\nsetDoc\n}\nfrom \"https://www.gstatic.com/firebasejs/12.0.0/firebase-firestore.js\";\n\nconst firebaseConfig = {\n\napiKey:\"AIzaSyAOdRVwmg-Mtfvc2UennLCI-4V1VO5Nnoc\",\n\nauthDomain:\"storequiz.firebaseapp.com\",\n\nprojectId:\"storequiz\"\n\n};\n\nconst app =\ninitializeApp(firebaseConfig);\n\nconst db =\ngetFirestore(app);\n\nwindow.getFirestoreQuiz =\nasync function(articleKey){\n\nconst ref =\ndoc(\ndb,\n'quizzes',\narticleKey\n);\n\nconst snap =\nawait getDoc(ref);\n\nif(\nsnap.exists()\n){\nreturn snap.data();\n}\n\nreturn null;\n\n};\n\n  \nwindow.saveFirestoreQuiz =\nasync function(\narticleKey,\nquestions\n){\n\n\n if(\n !Array.isArray(questions) ||\n questions.length === 0\n){\n\n console.log(\n \"Blocked empty Firestore save\"\n );\n\n return;\n}\n  await setDoc(\ndoc(\ndb,\n'quizzes',\narticleKey\n),\n{\nquestions,\ncreatedAt:Date.now()\n}\n);\n\n\nconsole.log(\n'Firebase Ready'\n);\n}\n</script>\n<script> \n  let userAnswers = {};\n  let quizLoading = false;\n   let QUIZ = [];window.onload = buildQuiz;\n function selectAnswer(questionIndex, optionIndex){\n\n    userAnswers[questionIndex] = optionIndex;\n\n    console.log(\n      \"Selected:\",\n      questionIndex,\n      optionIndex\n    );\n\n}\n\n\n\nfunction submitQuiz(){\n\nlet score = 0;\n\n\nQUIZ.forEach((q,index)=>{\n\n\nlet selected =\nuserAnswers[index];\n\n\nlet correct =\nq.options.indexOf(q.answer);\n\n\n\nlet inputs =\ndocument.querySelectorAll(\n`input[name=\"q${index}\"]`\n);\n\n\n\ninputs.forEach(\n(input,i)=>{\n\n\nlet label =\ninput.parentElement;\n\n\nlabel.style.backgroundColor=\"\";\n\n\nif(i === correct){\n\nlabel.style.backgroundColor =\n\"lightgreen\";\n\n}\n\n\nif(\nselected === i &&\ni !== correct\n){\n\nlabel.style.backgroundColor =\n\"tomato\";\n\n}\n\n\n});\n\n\nif(selected === correct){\nscore++;\n}\n\n\n});\n\n\nconsole.log(\n\"FINAL SCORE\",\nscore\n);\n\n\ndocument.getElementById(\"score\")\n.innerHTML =\n\"Score : \"+\nscore+\n\"/\"+\nQUIZ.length;\n\n\n}\n \n\nfunction saveLocalQuiz(\n  key,\n  questions\n){\n\nconsole.log(\n\"Saving LocalStorage:\",\nkey,\nquestions.length\n);\n\nlocalStorage.setItem(\n\"quiz_\" + key,\nJSON.stringify({\nquestions,\ncreatedAt: Date.now()\n})\n);\n\n}\n  \n  function getLocalQuiz(key){\n\nconst data =\nlocalStorage.getItem(\n\"quiz_\" + key\n);\n\nconsole.log(\n\"Local lookup:\",\n\"quiz_\" + key,\ndata\n);\n\nif(!data){\n   return null;\n}\n\nreturn JSON.parse(data).questions;\n\n}\n\n\n  const params =\nnew URLSearchParams(\nwindow.location.search\n);\n\nconst postUrl =\ndecodeURIComponent(\nparams.get('url')\n);\n\nconsole.log(postUrl);\n  \n\nfunction getArticleKey(url){\n\nreturn url\n.split('/')\n.pop()\n.replace('.html','');\n\n}\n\nconst articleKey =\ngetArticleKey(postUrl);\n\nconsole.log(articleKey);\n  function getLocalQuiz(articleKey){\n\nconst cached =\nlocalStorage.getItem(\narticleKey\n);\n\nif(cached){\n\nreturn JSON.parse(cached);\n\n}\n\nreturn null;\n\n}\n  async function fetchPost() {\n\nconst feedUrl =\n'https://interviewprepforinsiders.blogspot.com/feeds/posts/default?alt=json&max-results=5000';\n\nconst res =\nawait fetch(feedUrl);\n\nconst data =\nawait res.json();\n    \n\nconst entries =\ndata.feed.entry;\n\nconsole.log(entries.length);\n    \n\nfor(var i=0;i<entries.length;i++){\n\n   if(!entries[i].link){\n      continue;\n   }\n\n   var links =\n   entries[i].link;\n\n   for(var j=0;j<links.length;j++){\n\n      if(\n      links[j].rel === 'alternate'\n      ){\n\n         console.log(\n         links[j].href\n         );\n\n         if(\n         links[j].href === postUrl\n         ){\n\n            if(\n            !entries[i].content ||\n            !entries[i].content.$t\n            ){\n               return '';\n            }\n\n            var html =\n            entries[i].content.$t;\n\n            var div =\n            document.createElement('div');\n\n            div.innerHTML =\n            html;\n\n            var div =\ndocument.createElement('div');\n\ndiv.innerHTML = html;\n           \n\nvar buttons =\ndiv.querySelectorAll('button');\n\nfor(var i=0;i<buttons.length;i++){\n   buttons[i].remove();\n}\n/* remove styles */\n\nvar styles =\ndiv.querySelectorAll('style');\n\nfor(var i=0;i<styles.length;i++){\n   styles[i].remove();\n}\n\n\n/* remove scripts */\n\nvar scripts =\ndiv.querySelectorAll('script');\n\nfor(var i=0;i<scripts.length;i++){\n   scripts[i].remove();\n}\n\n\n/* remove links but keep text */\n\nvar links =\ndiv.querySelectorAll('a');\n\nfor(var i=0;i<links.length;i++){\n\n   links[i].replaceWith(\n      links[i].textContent\n   );\n\n}\n\n\nvar article =\ndiv.textContent;\n\narticle =\narticle.replace(/\\s+/g,' ')\n.trim();\n\nconsole.log(article);\n\nreturn article;\n         }\n\n      }\n\n   }\n\n}\n\nreturn '';\n\n}\nasync function buildQuiz(){\n if(quizLoading){\n    return;\n}\n\nquizLoading = true;\n\nquizLoading=true;\n  document.getElementById(\n\"debug\"\n).style.display=\"block\";\ndocument.getElementById(\"debug\").style.display=\"block\";\nconsole.log(\"STEP 1\");\n\nconst article =\nawait fetchPost();\n\nconsole.log(\"STEP 2\", article);\n\n/*document.getElementById(\n'debug'\n).innerHTML =\n'Article Length = ' +\narticle.length; */\n\nconst articleKey =\ngetArticleKey(postUrl);\n\nconsole.log(\"STEP 3\", articleKey);\n  \n  let questions = [];\n\n /* FIRESTORE LOOKUP */\n\nconst firestoreData =\nawait window.getFirestoreQuiz(\narticleKey\n);\n\nconsole.log(\"STEP 4\", firestoreData);\n  if(\nfirestoreData &&\nfirestoreData.questions &&\nfirestoreData.questions.length\n){\n\nconsole.log(\n'Loaded from Firestore'\n);\n\nquestions =\nfirestoreData.questions;\n\n/* refresh local cache */\n\nsaveLocalQuiz(\narticleKey,\nquestions\n);\n\nQUIZ =\nquestions;\n\nrenderQuiz();\n  document.getElementById(\n\"debug\"\n).style.display=\"none\";\n\n/* optional background refresh */\n\ngenerateMoreQuestions(\n article,\n articleKey,\n questions\n).catch(console.error);\n\nquizLoading=false;\nreturn;\n\n}\n\n\n/* LOCAL STORAGE BACKUP */\n\nquestions =\ngetLocalQuiz(articleKey);\n\nif(\nquestions &&\nquestions.length\n){\n\nconsole.log(\n'Loaded from Local Storage'\n);\n\nQUIZ =\nquestions;\n\nrenderQuiz();\ndocument.getElementById(\n\"debug\"\n).style.display=\"none\";\n  quizLoading=false;\nreturn;\n\n}\n\nconsole.log(\"STEP 5\", questions);\n \n\n/* GEMINI */\n\nconsole.log(\n'Generating from Gemini'\n);\n\n\n// safety: always keep array\nif(!Array.isArray(questions)){\n  questions = [];\n}\n\n\nconst data =\nawait generateQuiz(\n  article,\n  questions\n);\n\n\nconsole.log(\n\"GEMINI RESPONSE\",\ndata\n);\n\nif(\n !data ||\n !Array.isArray(data.questions)\n){\n\n console.error(\n \"Questions missing\",\n data\n );\n\n\n if(questions.length){\n\n   QUIZ = questions;\n   renderQuiz();\n  const loader =\ndocument.getElementById(\"debug\");\n\nif(loader){\n loader.style.display=\"none\";\n}\n   quizLoading=false;\n   return;\n\n }\n\n\n QUIZ=[];\n renderQuiz();\n const loader =\ndocument.getElementById(\"debug\");\n\nif(loader){\n loader.style.display=\"none\";\n}\n  quizLoading=false;\n return;   // add this\n\n}\n\n\n\n\n// new questions from Gemini\nconst newQuestions =\ndata.questions;\n\n\nconsole.log(\n\"New Gemini Questions:\",\nnewQuestions.length\n);\n\n\n// merge old + new\nquestions = [\n   ...questions,\n   ...newQuestions\n];\n\n\n// remove duplicates\nquestions =\nquestions.filter(\n(q,index,self)=>\n index ===\n self.findIndex(\n x =>\n x.question === q.question\n )\n);\n\n\nconsole.log(\n\"TOTAL QUESTIONS:\",\nquestions.length\n);\n\n\n// save updated cache\n\nif(\nquestions &&\nquestions.length\n){\n\nawait window.saveFirestoreQuiz(\n articleKey,\n questions\n);\n\n}\n\n\nsaveLocalQuiz(\n articleKey,\n questions\n);\n\n\nQUIZ =\nquestions;\n\n\nrenderQuiz();\n  \n const loader =\ndocument.getElementById(\"debug\");\n\nif(loader){\n loader.style.display=\"none\";\n}\n  quizLoading=false;\n  return;\n\n\n\n\n\n}\n\n\n\n\n\n\nfunction renderQuiz(){\n\nconst div =\ndocument.getElementById(\"quiz\");\n\ndiv.innerHTML=\"\";\n\n\nQUIZ.forEach((q,index)=>{\n\nlet html = `\n<div \nclass=\"question-card\"\nid=\"question-${index}\">\n\n<p>\n${index+1}. ${q.question}\n</p>\n`;\n\n\nq.options.forEach((option,i)=>{\n\nhtml += `\n<label>\n<input \ntype=\"radio\"\nname=\"q${index}\"\nonclick=\"selectAnswer(${index},${i})\">\n\n${option}\n\n</label><br>\n`;\n\n});\n\n\nhtml += \"</div>\";\n\ndiv.innerHTML += html;\n\n});\n\n\n}\n\n\n\n  \nasync function generateQuiz(\narticle,\nquestions\n){\n\nfor(\nlet attempt=1;\nattempt<=3;\nattempt++\n){\n\ntry{\n\nconst response =\nawait fetch(\n'https://generate-quiz-ten.vercel.app/api/generateQuiz',\n{\nmethod:'POST',\nheaders:{\n'Content-Type':'application/json'\n},\nbody: JSON.stringify({\n article: article,\n existingQuestions: questions\n})\n}\n);\n\nif(!response.ok){\n\nconst errorText =\nawait response.text();\n\nconsole.error(\n\"HTTP Error:\",\nresponse.status,\nerrorText\n);\n\nthrow new Error(\nerrorText\n);\n\n}\n\nconst text =\nawait response.text();\n\nconsole.log(\n\"API RAW RESPONSE\",\ntext\n);\n\nlet data;\n\ntry{\n\ndata =\nJSON.parse(text);\n\n}catch(err){\n\nconsole.error(\n\"Invalid JSON:\",\ntext\n);\n\nawait new Promise(\nr=>setTimeout(r,3000)\n);\n\ncontinue;\n\n}\n\nif(\nArray.isArray(data.questions)\n){\nreturn data;\n}\n\nconsole.log(\n\"Gemini retry\",\nattempt\n);\n\nawait new Promise(\nr=>setTimeout(r,3000)\n);\n\n}catch(err){\n\nconsole.error(\n\"Request failed\",\nerr\n);\n\n}\n\n}\n\nreturn {\nquestions:[]\n};\n\n}\nasync function generateMoreQuestions(\n  article,\n  articleKey,\n  existingQuestions\n){\n\ntry{\n\nconsole.log(\n\"Background Gemini generation...\"\n);\nconsole.log(\n\"Existing:\",\nexistingQuestions.length\n);\n  if(existingQuestions.length >= 50){\n\nconsole.log(\n\"Question limit reached\"\n);\n\nreturn;\n\n}\nlet data = null;\n\nfor(let i=0;i<3;i++){\n\ntry{\n\ndata =\nawait generateQuiz(\n  article,\n  existingQuestions\n);\n\nif(\n  data &&\n  Array.isArray(data.questions) &&\n  data.questions.length > 0\n){\n  break;\n}\n\n}catch(e){\n\nconsole.log(\n\"Background retry\",\ni + 1\n);\n\nawait new Promise(\nr => setTimeout(r,3000)\n);\n\n}\n\n}\n\nif(\n !data ||\n !Array.isArray(data.questions) ||\n data.questions.length === 0\n){\n\n console.log(\n \"No new questions generated\"\n );\n\n return;\n\n}\n\nconsole.log(\n\"New questions received:\",\ndata.questions.length\n);\n\nlet allQuestions = [\n\n  ...existingQuestions,\n\n  ...data.questions\n\n];\n\nallQuestions =\nallQuestions.filter(\n(q,index,self)=>\n\nindex ===\n\nself.findIndex(\nx =>\nx.question === q.question\n)\n\n);\n\nconsole.log(\n\"Updated total:\",\nallQuestions.length\n);\n\n  if(\nallQuestions.length <=\nexistingQuestions.length\n){\n\nconsole.log(\n\"No new questions. Skip save.\"\n);\n\nreturn;\n\n}\n  \nawait window.saveFirestoreQuiz(\n  articleKey,\n  allQuestions\n);\n\nsaveLocalQuiz(\n  articleKey,\n  allQuestions\n);\n\nQUIZ = allQuestions;\n  console.log(\n\"QUIZ LENGTH AFTER UPDATE\",\nQUIZ.length\n);\n\nrenderQuiz();\n\nconst debug =\ndocument.getElementById(\n\"debug\"\n);\n\nif(debug){\n  debug.style.display = \"none\";\n}\n\nconsole.log(\n\"Background cache updated\"\n);\n\n}\ncatch(err){\n\nconsole.error(\n\"Background generation failed\",\nerr\n);\n\n}\n\n}\n  </script>\n  <script>\n\n\n\n\nalert(\n\"Score : \"+\nscore+\n\"/\"+\nQUIZ.length\n);\n\n\ndocument\n.getElementById(\n\"submitBtn\"\n)\n.addEventListener(\n\"click\",\ncheckQuiz\n);\n\nfunction checkQuiz(){\n\nlet score = 0;\n\nQUIZ.forEach(\n(q,index)=>{\n\nif(q.type===\"fib\"){\n\nconst value =\n\ndocument\n.getElementById(\n'q' + index\n)\n.value\n.trim();\n\nif(\nvalue.toLowerCase()\n===\nq.answer.toLowerCase()\n){\nscore++;\n}\n\n}\n\nif(q.type===\"tf\"){\n\nconst selected =\n\ndocument.querySelector(\n'input[name=q' +\nindex +\n']:checked'\n);\n\nif(\nselected &&\nselected.value===\"true\"\n){\nscore++;\n}\n\n}\n\nif(q.type===\"mcq\"){\n\nconst selected =\n\ndocument.querySelector(\n'input[name=q' +\nindex +\n']:checked'\n);\n\nif(selected){\n   if(selected.value === q.answer){\n      score++;\n   }\n}\n\n}\n\n});\n\ndocument\n.getElementById(\n'result'\n)\n.innerHTML =\n'Score : ' +\nscore +\n' / ' +\nQUIZ.length;\n\n}\n</script>\n"
}