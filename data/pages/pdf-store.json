  "content": "<div id=\"pdfGrid\" class=\"pdf-grid\"></div>\n<script>\nconst PDFs = [\n\n{\n  name:\"Java Interview PDF\",\n  image:\"https://priyanka-nigam.github.io/JobsforTechWhiz.github.io/images/javaI.png\",\n  id:\"java\"\n},\n\n{\n  name:\"Spring Boot PDF\",\n  image:\"https://priyanka-nigam.github.io/JobsforTechWhiz.github.io/images/springb.jpg\",\n  id:\"spring\"\n},\n\n{\n  name:\"Android PDF\",\n  image:\"https://priyanka-nigam.github.io/JobsforTechWhiz.github.io/images/android.jpg\",\n  id:\"android\"\n},\n\n{\n  name:\"Microservices/docker PDF\",\n  image:\"https://priyanka-nigam.github.io/JobsforTechWhiz.github.io/images/docker.png\",\n  id:\"docker\"\n},\n\n{\n  name:\"PHP PDF\",\n  image:\"https://priyanka-nigam.github.io/JobsforTechWhiz.github.io/images/phpp.jpg\",\n  id:\"php\"\n},\n  {\n  name:\"App security and testing  PDF\",\n  image:\"https://priyanka-nigam.github.io/JobsforTechWhiz.github.io/images/web.jfif\",\n  id:\"app\"\n},\n  {\n  name:\"Client-server model PDF\",\n  image:\"https://priyanka-nigam.github.io/JobsforTechWhiz.github.io/images/client.png\",\n  id:\"client\"\n},\n  {\n  name:\"Git PDF\",\n  image:\"https://priyanka-nigam.github.io/JobsforTechWhiz.github.io/images/gitbash.png\",\n  id:\"git\"\n}\n  ,\n  {\n  name:\"Jenkins PDF\",\n  image:\"https://priyanka-nigam.github.io/JobsforTechWhiz.github.io/images/jenkin.png\",\n  id:\"jenkins\"\n}\n  ,\n  {\n  name:\"Jira PDF\",\n  image:\"https://priyanka-nigam.github.io/JobsforTechWhiz.github.io/images/jirap.png\",\n  id:\"jira\"\n}\n  ,\n  {\n  name:\"JSON PDF\",\n  image:\"https://priyanka-nigam.github.io/JobsforTechWhiz.github.io/images/jsonP.jfif\",\n  id:\"json\"\n} ,\n  {\n  name:\"Unix PDF\",\n  image:\"https://priyanka-nigam.github.io/JobsforTechWhiz.github.io/images/unix.png\",\n  id:\"unix\"\n}\n  \n\n];\n\nconst PRICE = \"?10\";\n\ndocument.getElementById(\"pdfGrid\").innerHTML =\nPDFs.map(pdf => `\n\n<div class=\"pdf-card\">\n\n<img\nsrc=\"${pdf.image}\"\nclass=\"pdf-image\"\nalt=\"${pdf.name}\">\n\n<h3>${pdf.name}</h3>\n\n<div class=\"price-tag\">\n${PRICE}\n</div>\n\n<button\nclass=\"buy-btn\"\nonclick=\"buyPDF('${pdf.id}')\">\n\nBuy Now\n\n</button>\n\n</div>\n\n`).join(\"\");\n  \n  function buyPDF(pdfId){\n    /*\nlocalStorage.setItem(\n    \"selectedPdf\",\n    pdfId\n  );\n\n  window.location.href =\n  \"payment.html\";\n  */\n   window.location.href =\n   \"/p/payment.html?pdf=\" +\n   encodeURIComponent(pdfId);\n\n}\n</script>\n\n<style>\n  .pdf-grid{\n    display:grid;\n    grid-template-columns:repeat(3,1fr);\n    gap:25px;\n}\n.pdf-card{\n\ntext-align:center;\n\nbackground:white;\n\npadding:20px;\n\nborder-radius:15px;\n\nbox-shadow:\n0 2px 10px rgba(0,0,0,.15);\n\n}\n.pdf-image{\n\nwidth:150px;\n\nheight:150px;\n\nborder-radius:50%;\n\nobject-fit:cover;\n\n}\n.price-tag{\n\nfont-size:22px;\n\nfont-weight:bold;\n\ncolor:#000;\n\nmargin:10px 0;\n\n}\n.buy-btn{\n\ndisplay:inline-block;\n\npadding:12px 12px;\n\nbackground:#ff6600;\n\ncolor:white;\n\nborder-radius:8px;\n\ntext-decoration:none;\n\nfont-weight:bold;\n\n}\n  .pdf-card h3{\n\n    color:#111 !important;\n\n    font-size:18px !important;\n\n    font-weight:700 !important;\n\n    margin:12px 0 !important;\n\n    display:block !important;\n\n    visibility:visible !important;\n\n}\n  body.dark-mode .pdf-card h3{\n    color:#fff !important;\n}\n</style>"
}