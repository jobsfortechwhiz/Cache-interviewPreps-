  "content": "<input\nid=\"quizSearch\"\ntype=\"text\"\nplaceholder=\"Search quiz by title or label...\"\nclass=\"quiz-search\">\n\n<div id=\"post-cards\"></div>\n<style>\n#post-cards{\n    display:grid;\n    grid-template-columns:repeat(3,minmax(0,1fr));\n    gap:16px;\n    width:100%;\n    margin:20px 0;\n}\n\n.post-card{\n    height:140px;\n    border:2px solid #ff9800;\n    border-radius:12px;\n    background:#ffffff;\n    color:#000000 !important;\n    cursor:pointer;\n\n    display:flex;\n    align-items:center;\n    justify-content:center;\n\n    padding:15px;\n    box-sizing:border-box;\n    text-align:center;\n\n    font-size:16px;\n    font-weight:700;\n    line-height:1.4;\n\n    overflow:hidden;\n\n    transition:all .25s ease;\n}\n\n.post-card:hover{\n    transform:translateY(-4px);\n    box-shadow:0 5px 15px rgba(0,0,0,.15);\n}\n\n.post-card span{\n    color:#000000 !important;\n    display:block !important;\n    width:100%;\n    word-break:break-word;\n}\n\n@media(max-width:768px){\n    #post-cards{\n        grid-template-columns:repeat(2,minmax(0,1fr));\n    }\n}\n\n@media(max-width:480px){\n    #post-cards{\n        grid-template-columns:1fr;\n    }\n}\n  .quiz-search{\nwidth:100%;\ndisplay:block;\nmax-width:none;\npadding:12px;\nmargin:20px 0;\nborder:2px solid #ff9800;\nborder-radius:8px;\nfont-size:16px;\nbox-sizing:border-box;\n}\n#quizSearch{\nwidth:100%;\nheight:56px;\n\npadding:12px 16px !important;\n\nfont-size:16px !important;\nline-height:1.4 !important;\n\ncolor:#000 !important;\nbackground:#fff !important;\n\nborder:2px solid #ff9800;\nborder-radius:10px;\n\nbox-sizing:border-box;\nvertical-align:middle;\n}\n\n#quizSearch::placeholder{\nfont-size:16px;\nline-height:1.4;\ncolor:#666;\n}\n #quizSearch{\n    width:100%;\n    height:60px;\n\n    font-size:20px !important;\n    line-height:60px !important;\n\n    padding:0 20px !important;\n\n    box-sizing:border-box;\n\n    color:#000 !important;\n    background:#fff !important;\n\n    text-indent:0 !important;\n\n    font-family:Arial,sans-serif !important;\n}\n\n#quizSearch::first-letter{\n    font-size:inherit !important;\n    line-height:inherit !important;\n    float:none !important;\n    margin:0 !important;\n}\n\n.quiz-search::first-letter{\n    font-size:inherit !important;\n    line-height:inherit !important;\n    float:none !important;\n    margin:0 !important;\n}\n#quizSearch::placeholder{\nfont-size:16px !important;\nfont-weight:400 !important;\nline-height:normal !important;\ncolor:#777;\n}\n  #quizSearch,\n#quizSearch::placeholder{\nfont-size:16px !important;\nline-height:1.2 !important;\ntext-transform:none !important;\nfont-family:Arial,sans-serif !important;\n}\n</style>\n\n<script src=\"https://www.gstatic.com/firebasejs/10.12.2/firebase-app-compat.js\"></script>\n\n<script src=\"https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore-compat.js\"></script>\n<script>\n  const firebaseConfig = {\n  apiKey: \"AIzaSyAOdRVwmg-Mtfvc2UennLCI-4V1VO5Nnoc\",\n  authDomain: \"storequiz.firebaseapp.com\",\n  projectId: \"storequiz\",\n  storageBucket: \"storequiz.firebasestorage.app\",\n  messagingSenderId: \"462730005071\",\n  appId: \"1:462730005071:web:23d37871959ee5f4e8783a\",\n  measurementId: \"G-SFRF5RK0KT\"\n};\n\nfirebase.initializeApp(firebaseConfig);\n\nconst db =\nfirebase.firestore();\nfetch(\"https://interviewprepforinsiders.blogspot.com/feeds/posts/default?alt=json&max-results=150\")\n.then(res => {\n    console.log(\"status=\", res.status);\n    return res.json();\n})\n.then(async data => {\n\nconst quizSnapshot =\nawait db.collection(\"quizzes\").get();\n\nconst validSlugs =\nnew Set();\n\nquizSnapshot.forEach(doc => {\n\nvalidSlugs.add(doc.id);\n\n});\n\nconsole.log(\n\"Firebase quizzes:\",\nvalidSlugs.size\n);\n\nlet html = '';\n\n\ndata.feed.entry.forEach(function(post){\n\n    var title = post.title.$t;\n  var postUrl =\npost.link.find(function(l){\n\nreturn l.rel === \"alternate\";\n\n}).href;\n\n\n    var labels = post.category\n        ? post.category.map(function(c){\n              return c.term;\n          })\n        : [];\nconsole.log(\ntitle,\nlabels\n);\n \n   if (\n    labels.some(function(label){\n        return label.toLowerCase()\n        .includes(\"managerial interview questions\");\n    })\n){\n    return;\n}\n  const box =\ndocument.getElementById(\"quizSearch\");\n\nbox.addEventListener(\"keyup\", function(){\n\nconsole.log(\n\"TYPING:\",\nthis.value\n);\n\n});\n  var postUrl =\npost.link.find(function(l){\n    return l.rel === \"alternate\";\n}).href;\n\nvar slug =\npostUrl\n.split(\"/\")\n.pop()\n.replace(\".html\",\"\");\n  \n  if(\n!validSlugs.has(slug)\n){\n   return;\n}\n\nhtml += '<div class=\"post-card\" ' +\n        'onclick=\"openQuiz(this)\" ' +\n        'data-slug=\"' + slug + '\"' +\n   'data-title=\"' + title.toLowerCase() + '\">' +\n        '<span>' + title + '</span>' +\n        '</div>';\n\n});\n\ndocument.getElementById('post-cards').innerHTML = html;\n\nconsole.log(\n    document.querySelectorAll('.post-card').length\n);\n  \n  /*-------------------search --------------*/\ndocument.getElementById(\"quizSearch\")\n.addEventListener(\"input\", function(){\n\nconst search =\nthis.value.toLowerCase().trim();\n\ndocument\n.querySelectorAll(\".post-card\")\n.forEach(card => {\n\nconst text =\ncard.getAttribute(\"data-title\");\n\ncard.style.display =\ntext.includes(search)\n? \"flex\"\n: \"none\";\n\n});\n\n});\n});\n     /*\nvar html = '';\n\nhtml += '<div class=\"post-card\"><span>Java</span></div>';\nhtml += '<div class=\"post-card\"><span>Spring</span></div>';\n  */\n\n\nfunction openQuiz(card){\n/*  var title = card.getAttribute('data-title');\n\n    window.location.href =\n      '/p/tech-quiz.html?title=' + title;\n      \n      */\n    var slug =\n    card.getAttribute('data-slug');\n\n    window.location.href =\n      '/p/tech-quiz.html?slug=' + slug;\n\n}\n</script>"
}
