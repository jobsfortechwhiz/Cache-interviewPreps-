  "id": "tag:blogger.com,1999:blog-3116858574126921604.page-3987937563755619201",
  "title": "Tech Quiz",
  "slug": "tech-quiz",
  "updated": "2026-06-23T17:39:50.999+05:30",
  "author": "Priya",
  "content": "<style>\n  .question{\n    margin-bottom:20px;\n}\n\n.question-title{\n    margin:0 0 8px 0;\n    font-size:18px;\n}\n\n.option-label{\n    display:block;\n    margin:2px 0;\n    padding:6px 10px;\n    cursor:pointer;\n}\n\n.option-label input{\n    margin-right:8px;\n}\n.correct-option{\n    background:#d4edda;\n    border:2px solid #28a745;\n    color:#155724;\n    padding:10px;\n    border-radius:6px;\n    display:block;\n    margin:5px 0;\n}\n\n.wrong-option{\n    background:#f8d7da;\n    border:2px solid #dc3545;\n    color:#721c24;\n    padding:10px;\n    border-radius:6px;\n    display:block;\n    margin:5px 0;\n}\n\n.option-label{\n    padding:8px;\n    display:block;\n    border-radius:5px;\n    margin:4px 0;\n}\n</style>\n<h1 id=\"quizTitle\"></h1>\n<script>\n/*\n  const params = new URLSearchParams(\n  .location.search);\nconst title = decodeURIComponent(params.get(\"title\") || \"\");\n\nconsole.log(title);\n*/\n  \n  const params =\nnew URLSearchParams(\nwindow.location.search\n);\n\nconst quizId =\nparams.get(\"slug\");\n\nconsole.log(\n\"Quiz ID:\",\nquizId\n);\n\n// Example:\ndocument.getElementById(\"quizTitle\").textContent =\n    title + \" Quiz\";\n</script>\n\n<script type=\"module\">\n\nlet quizData = null;\nlet correctAnswers = [];\nimport { initializeApp } \nfrom \"https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js\";\n\n\nimport {\ngetFirestore,\ndoc,\ngetDoc\n}\nfrom \"https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore.js\";\n\n\n\nconst firebaseConfig={\n\napiKey: \"AIzaSyAOdRVwmg-Mtfvc2UennLCI-4V1VO5Nnoc\",\n\nauthDomain:\"storequiz.firebaseapp.com\",\n\nprojectId:\"storequiz\",\n  storageBucket:\"storequiz.firebasestorage.app\",\n\nmessagingSenderId:\"462730005071\",\n\nappId:\"1:462730005071:web:23d37871959ee5f4e8783a\"\n\n};\n\n\nconst app=initializeApp(firebaseConfig);\n\n\nconst db=getFirestore(app);\n\n\n\n// get quiz id from URL\n\n\nconst params=new URLSearchParams(\nwindow.location.search\n);\n\n/*\n  const title = params.get(\"title\");\n\nconst quizId = title\n    .toLowerCase()\n    .replace(/\\s+/g, \"-\");\n    */\n\nconsole.log(quizId);\n\nconsole.log(\"quizId =\", quizId);\n\n\n\n\nasync function loadQuiz(){\n\nconsole.log(\"Searching document:\", quizId);\nconst quizRef=\ndoc(db,\"quizzes\",quizId);\n\nconst snapshot = await getDoc(quizRef);\n\nconsole.log(snapshot.exists());\n\n\n\nif(snapshot.exists()){\n\nquizData = snapshot.data();\n  console.log(\n\"FIRST QUESTION = \",\nJSON.stringify(quizData.questions[0], null, 2)\n);\n\nconsole.log(\"FULL DATA =\", quizData);\nconsole.log(\"QUESTIONS =\", quizData.questions);\nconsole.log(\"TYPE =\", typeof quizData.questions);\n\n\n\ndocument.getElementById(\"quizTitle\").innerHTML =\n    params.get(\"title\") || quizId;\n\n\n\nlet html = \"\";\n\ncorrectAnswers = [];\n\nquizData.questions.forEach(function(q, index) {\n\n    correctAnswers[index] = q.answer;\n\n   html += \"<div class='question'>\";\n\nhtml += \"<h3 class='question-title'>\" +\n        (index + 1) +\n        \". \" +\n        q.question +\n        \"</h3>\";\n\nq.options.forEach(function(option) {\n\n    html += \"<label class='option-label'>\";\n    html += \"<input type='radio' \" +\n            \"name='q\" + index + \"' \" +\n            \"value=\\\"\" + option + \"\\\">\";\n    html += \"<span>\" + option + \"</span>\";\n    html += \"</label>\";\n\n});\n\nhtml += \"</div>\";\n});\n\nconsole.log(\"HTML Length:\", html.length);\n\ndocument.getElementById(\"quizBox\").innerHTML = html;\n\n\n\n}\n\nelse{\n\ndocument.body.innerHTML=\n\"Quiz not found\";\n\n}\n\n\n}\n\n\n\nloadQuiz();\n\n\n\n\nwindow.submitQuiz = function(){\n\n    let score = 0;\n\n    quizData.questions.forEach(function(q,index){\n\n        let selected =\n        document.querySelector(\n            \"input[name='q\"+index+\"']:checked\"\n        );\n\n        let allOptions =\n        document.querySelectorAll(\n            \"input[name='q\"+index+\"']\"\n        );\n\n        allOptions.forEach(function(radio){\n\n            let label = radio.parentElement;\n\n            radio.disabled = true;\n\n            // Correct answer\n            if(radio.value === q.answer){\n\n                label.classList.add(\"correct-option\");\n\n                if(!label.innerHTML.includes(\"?\")){\n                    label.innerHTML +=\n                    \" <span style='float:right;font-weight:bold'>? Correct</span>\";\n                }\n            }\n\n            // Wrong selected answer\n            if(\n                selected &&\n                radio.value === selected.value &&\n                selected.value !== q.answer\n            ){\n\n                label.classList.add(\"wrong-option\");\n\n                if(!label.innerHTML.includes(\"?\")){\n                    label.innerHTML +=\n                    \" <span style='float:right;font-weight:bold'>? Your Choice</span>\";\n                }\n            }\n\n        });\n\n        if(\n            selected &&\n            selected.value === q.answer\n        ){\n            score++;\n        }\n\n    });\n\n    document.getElementById(\"result\").innerHTML =\n        \"Score: \" + score + \" / \" + quizData.questions.length;\n\n};\n\n</script>\n<h1 id=\"quizTitle\"></h1>\n\n\n<form id=\"quizBox\"></form>\n\n\n<button onclick=\"submitQuiz()\">\nSubmit Quiz\n</button>\n\n\n<h2 id=\"result\"></h2>"
}